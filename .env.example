# ─────────────────────────────────────────
# SharpEdge Environment Variables
# Rename this file to .env and fill in your keys
# NEVER commit .env to GitHub — it stays on your machine / Vercel dashboard
# ─────────────────────────────────────────

# 1. The Odds API — live spreads, moneylines, O/U
#    Free: 500 req/month | Get key: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# 2. API-Sports — team stats, injury reports, standings
#    Free: 100 req/day | Get key: https://api-sports.io
API_SPORTS_KEY=your_api_sports_key_here

# 3. Anthropic — Claude AI picks engine
#    Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 4. balldontlie — free NBA player stats (no key needed, just set to "free")
BALL_DONT_LIE=free
